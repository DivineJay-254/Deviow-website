<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # Redirects for merged pages
  RewriteRule ^values/?$ /about#values [R=301,L]
  RewriteRule ^play-and-grow/?$ /programs#play-and-grow [R=301,L]
  RewriteRule ^gallery/?$ /impact#gallery [R=301,L]
  
  # Prevent rewriting for existing files and directories
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  
  # Rewrite all requests to index.html for clean URLs
  RewriteRule ^(.*)$ /index.html [L]
</IfModule>

<IfModule mod_headers.c>
  # Add caching headers for images
  <FilesMatch "\.(jpg|jpeg|png|gif|ico|svg)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  
  # Add proper MIME types
  <FilesMatch "\.css$">
    Header set Content-Type "text/css"
  </FilesMatch>
  <FilesMatch "\.js$">
    Header set Content-Type "application/javascript"
  </FilesMatch>
</IfModule>

{
  "redirects": [
    {
      "source": "/values",
      "destination": "/about#values",
      "statusCode": 301
    },
    {
      "source": "/play-and-grow",
      "destination": "/programs#play-and-grow",
      "statusCode": 301
    },
    {
      "source": "/gallery",
      "destination": "/impact#gallery",
      "statusCode": 301
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/styles.css",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/css"
        }
      ]
    },
    {
      "source": "/script.js",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/javascript"
        }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
